# =============================================================================
# DÉVELOPPEMENT LOCAL : AUCUNE configuration nécessaire.
# L'app utilise une base SQLite (prisma/dev.db) créée automatiquement et l'IA
# tourne en mode démo. Lancez simplement `pnpm install` puis `pnpm dev`.
#
# Ce fichier ne sert qu'à la PRODUCTION (Vercel) ou pour activer l'IA réelle.
# Pour des secrets locaux, créez un fichier `.env.local` (ignoré par git).
# =============================================================================

# Clé API Claude — OPTIONNELLE (locale ET production).
# Si vide, la génération IA tourne en mode démo déterministe (app pleinement
# utilisable). Si présente, génération réelle via Claude.
ANTHROPIC_API_KEY=""

# --- PRODUCTION uniquement (Vercel) — ignorés en local (SQLite) ---

# Base de données PostgreSQL (Neon, Vercel Postgres, Supabase, RDS…)
# Exemple Neon : postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/postulo?sslmode=require"

# Secret de signature des sessions — générez une valeur forte :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me"
