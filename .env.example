# Base de données PostgreSQL (Neon, Vercel Postgres, Supabase, RDS…)
# Exemple Neon : postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/postulo?sslmode=require"

# Secret de signature des sessions — générez une valeur forte :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me"

# Clé API Claude — OPTIONNELLE. Si vide, la génération IA tourne en mode démo
# déterministe (l'app reste pleinement utilisable).
ANTHROPIC_API_KEY=""
