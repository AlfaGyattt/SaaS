// Postulo — schéma PRODUCTION (PostgreSQL).
// Utilisé uniquement au build Vercel (cf. vercel.json :
//   prisma generate --schema=prisma/schema.postgres.prisma).
// Identique à prisma/schema.prisma (SQLite, dev local) hormis la datasource.
// Garder les deux fichiers synchronisés lors d'un changement de modèle.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  locale       String        @default("fr")
  plan         String        @default("FREE") // FREE | PASS | PRO | CARRIERE
  planUntil    DateTime?
  resumes      Resume[]
  letters      Letter[]
  offers       JobOffer[]
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Resume {
  id         String        @id @default(cuid())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  title      String
  romeCode   String?
  templateId String        @default("sobre")
  data       String        @default("{}") // ResumeData sérialisé
  atsScore   Int?
  tag        String?
  applications Application[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([userId])
}

model Letter {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  body      String
  tone      String   @default("sobre")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model JobOffer {
  id           String        @id @default(cuid())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  sourceUrl    String?
  rawText      String
  title        String?
  company      String?
  requirements String        @default("[]") // Requirement[] sérialisé
  applications Application[]
  createdAt    DateTime      @default(now())

  @@index([userId])
}

model Application {
  id             String    @id @default(cuid())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  offer          JobOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)
  offerId        String?
  resume         Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  resumeId       String?
  company        String
  role           String
  city           String?
  status         String    @default("BROUILLON") // BROUILLON|ENVOYEE|RELANCEE|ENTRETIEN|OFFRE|REFUSEE
  matchScore     Int?
  letterBody     String?
  mailSubject    String?
  mailBody       String?
  prepKit        String?
  cvTips         String?
  keywords       String?
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, status])
}
